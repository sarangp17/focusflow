{
  "manifest_version": 3,
  "name": "FocusFlow Tracker",
  "version": "1.0",
  "description": "Sends active tab URL to FocusFlow for productivity tracking",
  "permissions": [
    "tabs",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}